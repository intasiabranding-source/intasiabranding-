# Database — Neon (recommended): paste from https://console.neon.tech → Connection string
# Must include ?sslmode=require at the end
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Local Docker alternative: scripts\start-db.bat then use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digital_growth?schema=public"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Encryption (32-byte hex for AES-256-GCM)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Admin seed emails
ADMIN_PRIMARY_EMAIL="admin@example.com"
ADMIN_BACKUP_EMAIL="backup@example.com"

# SMTP (used for admin OTP login, contact form, lead emails)
# Dashboard profile overrides these when an active profile is saved.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="gmail-16-char-app-password"
SMTP_ENCRYPTION="TLS"
SMTP_FROM_EMAIL="you@gmail.com"
SMTP_FROM_NAME="Digital Growth Ecosystem"
# Windows dev only if TLS cert errors: SMTP_TLS_INSECURE="true"

# Resend (optional fallback if useSmtpForAuth is disabled in admin)
RESEND_API_KEY=""
EMAIL_FROM="noreply@example.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Analytics
GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="your-cron-secret"
