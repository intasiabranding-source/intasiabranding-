import "dotenv/config";


const databaseUrl = process.env.DATABASE_URL;

if (!databaseUrl) {
  throw new Error("DATABASE_URL is not set");
}

/**
 * Prisma 7 config (CommonJS for Prisma config parser compatibility).
 */
const config = {
  datasources: {
    db: {
      url: databaseUrl,
    },
  },
};

module.exports = config;
