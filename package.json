    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.3",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.15.0",
    "gsap": "^3.12.5",
    "isomorphic-dompurify": "^2.19.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
