{
  "name": "digital-growth-ecosystem",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/tailwindcss/lib/cli.js -i ./static/css/input.css -o ./static/css/main.css --minify && node scripts/copy-static-to-public.js && next dev",
    "build": "npm run static:build && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:check": "tsx scripts/check-db.ts",
    "smtp:test": "tsx scripts/test-smtp-direct.ts",
    "static:css": "node node_modules/tailwindcss/lib/cli.js -i ./static/css/input.css -o ./static/css/main.css --minify",
    "static:build": "node node_modules/tailwindcss/lib/cli.js -i ./static/css/input.css -o ./static/css/main.css --minify && node scripts/copy-static-to-public.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
